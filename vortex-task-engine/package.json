{
  "name": "vortex-task-engine",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev:api": "nodemon --watch 'api/**/*' --watch 'shared/**/*' -e ts --exec 'node --import tsx api/src/server.ts'",
    "dev:worker": "nodemon --watch 'worker/**/*' --watch 'shared/**/*' -e ts --exec 'node --import tsx worker/src/processor.ts'",
    "dev": "concurrently \"npm run dev:api\" \"npm run dev:worker\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0"
  }
}
